GEMINI_API_KEY=your_gemini_api_key_here
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_SCHEMA=v57
PORT=8000
STORAGE_PATH=./storage/forge-assets
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# LLM Provider API Keys (configure which providers are available)
GROQ_API_KEY=your_groq_key_here
TOGETHER_API_KEY=your_together_key_here
OPENROUTER_API_KEY=your_openrouter_key_here
OPENAI_API_KEY=your_openai_key_here

# Default model fallback (used when a step has no model configured in DB)
# Format: provider:model_name
DEFAULT_MODEL=gemini:gemini-2.5-flash

# Feedback executive summary (uses its own Gemini key/model, not step_configs)
FEEDBACK_SUMMARY_API_KEY=your_gemini_api_key_here
FEEDBACK_SUMMARY_MODEL=gemini:gemini-2.0-flash

# Image generation providers
FAL_KEY=your_fal_key_here
HF_TOKEN=your_hf_token_here

# Cloudflare R2 storage
CF_ACCOUNT_ID=your_cf_account_id
CF_R2_ACCESS_KEY_ID=your_r2_access_key
CF_R2_SECRET_ACCESS_KEY=your_r2_secret_key
CF_R2_BUCKET=forge-assets
CF_R2_PUBLIC_URL=https://your-bucket.r2.dev
CF_R2_FEEDBACK_BUCKET=feedback-screenshots
CF_R2_FEEDBACK_PUBLIC_URL=https://your-feedback-bucket.r2.dev

# ComfyUI Cloud
COMFYUI_BASE_URL=https://cloud.comfy.org
COMFYUI_API_KEY=your_comfyui_api_key_here

# Note: per-step model config and image generation config are managed
# from the admin panel at /admin/integrations — not via env vars.
