GEMINI_API_KEY=your_gemini_api_key_here
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_SCHEMA=v57
PORT=8000
STORAGE_PATH=./storage/forge-assets
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# LLM Provider API Keys
GROQ_API_KEY=your_groq_key_here
TOGETHER_API_KEY=your_together_key_here
OPENROUTER_API_KEY=your_openrouter_key_here

# Model configuration per wizard step
# Format: provider:model_name  (provider = gemini | groq | together | openrouter)
# Leave empty to use DEFAULT_MODEL

DEFAULT_MODEL=gemini:gemini-2.5-flash

# Wizard steps
STEP_1_GDD_MODEL=gemini:gemini-2.5-flash
STEP_2_SPRITES_MODEL=gemini:gemini-2.5-flash-lite
STEP_3_LEVELS_MODEL=gemini:gemini-2.5-flash
STEP_4_CODE_MODEL=groq:llama-3.3-70b-versatile
STEP_5_AUDIO_MODEL=gemini:gemini-2.5-flash-lite
VALIDATION_MODEL=gemini:gemini-2.5-flash-lite

# Pipeline nodes (2D)
PIPELINE_VISUAL_GUIDE_MODEL=gemini:gemini-2.5-flash-lite
PIPELINE_CONCEPT_ART_MODEL=gemini:gemini-2.5-flash-lite
PIPELINE_BACKGROUNDS_MODEL=gemini:gemini-2.5-flash-lite
PIPELINE_SFX_MODEL=gemini:gemini-2.5-flash-lite
PIPELINE_UIUX_MODEL=gemini:gemini-2.5-flash-lite
PIPELINE_ICONS_MODEL=gemini:gemini-2.5-flash-lite
PIPELINE_HUD_MODEL=gemini:gemini-2.5-flash-lite

# Pipeline nodes (3D) — modeling, characters, vfx, texturing, rigging, lighting, animation, cinematics, voice
PIPELINE_3D_MODEL=gemini:gemini-2.5-flash
